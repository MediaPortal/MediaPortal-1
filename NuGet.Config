<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <add key="repositoryPath" value="Packages" />
  </config>
  <packageRestore>
    <add key="enabled" value="True" />
  </packageRestore>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="TeamMediaPortal source @ MyGet" value="https://www.myget.org/F/mediaportal/api/v2" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="TeamMediaPortal source @ MyGet">
      <package pattern="ANT" />
      <package pattern="BASS*" />
      <package pattern="DirectX_9_SDK" />
      <package pattern="MediaPortal.*" />
      <package pattern="Sqlite" />
      <package pattern="UnidecodeSharpFork*" />
      <package pattern="vsyasm" />
    </packageSource>
  </packageSourceMapping>
  <disabledPackageSources />
</configuration>